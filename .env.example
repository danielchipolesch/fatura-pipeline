# === LLM Fallback — Ollama (open source, self-hosted) ===
# Usado apenas como exceção quando a extração determinística falha.
# O modelo é baixado automaticamente na primeira vez que o fallback é acionado.
#
# Modelos recomendados para CPU sem GPU:
#   qwen2.5:3b   — Apache 2.0, multilingual (ótimo para PT-BR), ~2 GB  [padrão]
#   llama3.2:3b  — Meta Community License, ~2 GB
#   mistral:7b   — Apache 2.0, mais capaz mas mais lento (~4 GB, ~3-5 min/arquivo em CPU)
#
LLM_FALLBACK_ENABLED=true
LLM_MODEL=qwen2.5:3b
# URL do Ollama — quando usando docker-compose, o nome do serviço resolve automaticamente.
# Se o Ollama rodar na máquina host (fora do Docker): http://host.docker.internal:11434
LLM_BASE_URL=http://ollama:11434

# === Pipeline ===
# Limiar de confiança abaixo do qual o LLM fallback é acionado (0.0 a 1.0)
CONFIDENCE_THRESHOLD=0.60

# === Processamento ===
# Modo watch: monitora a pasta input/ continuamente (true/false)
WATCH_MODE=false
# Intervalo de polling em segundos (somente no modo watch)
POLL_INTERVAL_SECONDS=30

# === Docling ===
# Modo de OCR: auto (detecta PDFs escaneados e aplica OCR só quando necessário,
# recomendado) | always (força OCR em todos os PDFs, mais lento) | never (desabilita)
DOCLING_OCR_MODE=auto
# Idioma(s) do Tesseract OCR, separados por vírgula (ex: por,eng)
DOCLING_OCR_LANG=por
# Habilitar detecção de estrutura de tabelas via ML
DOCLING_TABLE_STRUCTURE=true

# === Logging ===
LOG_LEVEL=INFO
